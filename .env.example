# Which LLM provider the Agent Generator uses: claude | openai | gemini
LLM_PROVIDER=claude

# Model override (optional — each provider has a sensible default)
LLM_MODEL=

# Provider credentials (set the one matching LLM_PROVIDER)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# App
MISELOOP_ENV=dev
LOG_LEVEL=INFO
