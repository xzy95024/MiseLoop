# Which LLM provider the Agent Generator uses: claude | openai | gemini
LLM_PROVIDER=claude

# Model override (optional — each provider has a sensible default)
LLM_MODEL=

# Provider credentials (set the one matching LLM_PROVIDER)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Nexla — context layer tries Nexla first, falls back to local extraction on timeout/error.
# Put the REAL service key only in .env (never in this committed example file).
NEXLA_API_KEY=
NEXLA_API_BASE=https://dataops.nexla.io/nexla-api
NEXLA_TIMEOUT_SECONDS=60
# Auth: auto (try /token service-key exchange, fall back to key-as-bearer) | bearer | token_exchange
NEXLA_AUTH_MODE=auto
# Records endpoint path template ({id} is substituted). Real Nexla read endpoint is /samples.
NEXLA_RECORDS_PATH=/data_sets/{id}/samples
# Per-source unified Nexset ids (read both, combine locally).
# Leave blank to skip Nexla and use local extraction directly.
NEXLA_PDF_RESOURCE_ID=
NEXLA_XLSX_RESOURCE_ID=

# App
MISELOOP_ENV=dev
LOG_LEVEL=INFO
